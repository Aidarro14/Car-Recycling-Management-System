@model IEnumerable<CarRecyclingWeb.Models.RecyclingPoint>

@{
    ViewData["Title"] = "Пункты утилизации";
}

<div class="container py-5">
    <h1 class="mb-3 text-center display-4 text-primary">
        <i class="bi bi-geo-alt-fill me-3"></i> @ViewData["Title"]
    </h1>
    <p class="lead text-center mb-5 text-secondary">
        Найдите ближайший пункт для утилизации вашего автомобиля или его частей. <br />
        Воспользуйтесь нашей сетью проверенных центров для быстрого и удобного обслуживания.
    </p>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 justify-content-center">
            @foreach (var item in Model)
            {
                <div class="col d-flex">
                    @* Добавляем d-flex, чтобы карточки были одной высоты *@
                    <div class="card h-100 shadow-lg border-0 rounded-3 overflow-hidden">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top object-fit-cover" alt="Изображение пункта @item.Name" style="height: 200px;">
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/400x200/e9ecef/adb5bd?text=Изображение+недоступно" class="card-img-top object-fit-cover" alt="Изображение недоступно" style="height: 200px;">
                        }

                        <div class="card-body d-flex flex-column p-4">
                            @* Увеличиваем padding *@
                            <h5 class="card-title mb-3 fs-4 text-dark">@Html.DisplayFor(modelItem => item.Name)</h5>

                            <p class="card-text mb-2 text-secondary">
                                <i class="bi bi-geo-alt me-2 text-primary"></i> @Html.DisplayFor(modelItem => item.Address)
                            </p>

                            @if (!string.IsNullOrEmpty(item.PhoneNumber))
                            {
                                <p class="card-text mb-2 text-secondary">
                                    <i class="bi bi-telephone me-2 text-primary"></i> <a href="tel:@item.PhoneNumber" class="text-decoration-none text-secondary">@Html.DisplayFor(modelItem => item.PhoneNumber)</a>
                                </p>
                            }
                            else
                            {
                                <p class="card-text mb-2 text-secondary fst-italic">
                                    <i class="bi bi-telephone me-2 text-primary"></i> Телефон не указан
                                </p>
                            }

                            @if (!string.IsNullOrEmpty(item.OpeningHours))
                            {
                                <p class="card-text mb-2 text-secondary">
                                    <i class="bi bi-clock me-2 text-primary"></i> Часы работы: @Html.DisplayFor(modelItem => item.OpeningHours)
                                </p>
                            }
                            else
                            {
                                <p class="card-text mb-2 text-secondary fst-italic">
                                    <i class="bi bi-clock me-2 text-primary"></i> Часы работы не указаны
                                </p>
                            }

                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="card-text small text-muted mb-4">
                                    @Html.DisplayFor(modelItem => item.Description)
                                </p>
                            }
                            else
                            {
                                <p class="card-text small text-muted mb-4 fst-italic">
                                    Описание отсутствует.
                                </p>
                            }

                            <div class="mt-auto pt-3 border-top">
                                @* Прижимает футер к низу карточки *@
                                @if (!string.IsNullOrEmpty(item.MapUrl))
                                {
                                    <a href="@item.MapUrl" target="_blank" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-map me-2"></i> Показать на карте
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-secondary w-100" disabled>
                                        <i class="bi bi-map-fill me-2"></i> Карта недоступна
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-4" role="alert">
            <h4 class="alert-heading mb-3"><i class="bi bi-info-circle-fill me-2"></i> Нет данных о пунктах утилизации</h4>
            <p>К сожалению, на данный момент информация о пунктах утилизации не найдена.</p>
            <hr>
            <p class="mb-0">Мы работаем над добавлением новых пунктов. Пожалуйста, зайдите позже или свяжитесь с нами для получения дополнительной информации.</p>
        </div>
    }
</div>

@section Scripts {
}