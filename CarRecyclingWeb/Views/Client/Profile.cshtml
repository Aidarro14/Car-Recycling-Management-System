@model CarRecyclingWeb.Models.Client

@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container py-5">
    <h1 class="mb-4 text-center display-4 text-primary">
        <i class="bi bi-person-circle me-3"></i> @ViewData["Title"]
    </h1>
    <p class="lead text-center mb-5 text-secondary">
        Управляйте своей учетной записью и просматривайте свои действия.
    </p>

    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg rounded-3 mb-5">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <img src="https://via.placeholder.com/90/007bff/ffffff?text=AV" alt="Аватар пользователя" class="rounded-circle me-4 border border-primary border-3" style="width: 90px; height: 90px; object-fit: cover;">
                        <div>
                            <h2 class="card-title mb-1 text-dark">
                                @Html.DisplayFor(model => model.FirstName) @Html.DisplayFor(model => model.LastName)
                            </h2>
                            <p class="text-muted mb-0">
                                <i class="bi bi-envelope-fill me-2"></i> @Html.DisplayFor(model => model.Email)
                            </p>
                            @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                            {
                                <p class="text-muted mb-0">
                                    <i class="bi bi-phone-fill me-2"></i> @Html.DisplayFor(model => model.PhoneNumber)
                                </p>
                            }
                            else
                            {
                                <p class="text-muted mb-0 fst-italic">
                                    <i class="bi bi-phone-fill me-2"></i> Телефон не указан
                                </p>
                            }
                        </div>
                    </div>

                    <h5 class="mb-3 text-primary">Обзор активности</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6 col-lg-4">
                            <div class="card bg-light border-0 shadow-sm">
                                <div class="card-body text-center py-3">
                                    <h4 class="mb-1 text-primary">
                                        <i class="bi bi-car-front-fill me-2"></i> @(Model.Cars?.Count ?? 0)
                                    </h4>
                                    <small class="text-muted">Моих автомобилей</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="card bg-light border-0 shadow-sm">
                                <div class="card-body text-center py-3">
                                    <h4 class="mb-1 text-primary">
                                        <i class="bi bi-file-earmark-text-fill me-2"></i> @(Model.Requests?.Count ?? 0)
                                    </h4>
                                    <small class="text-muted">Моих заявок</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-12 col-lg-4">
                            <div class="card bg-light border-0 shadow-sm">
                                <div class="card-body text-center py-3">
                                    <h4 class="mb-1 text-primary">
                                        <i class="bi bi-calendar-check-fill me-2"></i> 0
                                    </h4>
                                    <small class="text-muted">Завершено утилизаций</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="container py-5">
                        <h5 class="mb-3 text-primary">Управление аккаунтом</h5>
                        <div class="d-grid gap-3">
                            <a asp-action="EditProfile" asp-controller="Client" class="btn btn-outline-dark btn-lg d-flex align-items-center justify-content-center">
                                <i class="bi bi-gear-fill me-3"></i> Изменить данные профиля
                            </a>
                            <a asp-action="ChangePassword" asp-controller="Client" class="btn btn-outline-dark btn-lg d-flex align-items-center justify-content-center">
                                <i class="bi bi-key-fill me-3"></i> Изменить пароль
                            </a>
                            <a asp-action="MyCars" asp-controller="Client" class="btn btn-outline-dark btn-lg d-flex align-items-center justify-content-center">
                                <i class="bi bi-car-front-fill me-3"></i> Мои автомобили (@(Model.Cars?.Count ?? 0))
                            </a>
                            <a asp-action="MyRequests" asp-controller="Client" class="btn btn-outline-dark btn-lg d-flex align-items-center justify-content-center">
                                <i class="bi bi-file-earmark-text-fill me-3"></i> Мои заявки (@(Model.Requests?.Count ?? 0))
                            </a>
                        </div>

                        <div class="text-center mt-4">
                            <a asp-action="Logout" asp-controller="Client" class="btn btn-danger btn-lg">
                                <i class="bi bi-box-arrow-right me-2"></i> Выйти из аккаунта
                            </a>
                        </div>
                    </div>
    </div>
</div>

@section Scripts {
}