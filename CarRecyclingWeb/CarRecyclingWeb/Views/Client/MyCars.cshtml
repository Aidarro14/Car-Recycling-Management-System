@model IEnumerable<CarRecyclingWeb.Models.Car>

@{
    ViewData["Title"] = "Мои автомобили";
}

<div class="container py-5">
    <h1 class="mb-4 text-center display-4 text-primary">
        <i class="bi bi-car-front-fill me-3"></i> @ViewData["Title"]
    </h1>
    <p class="lead text-center mb-5 text-secondary">
        Список автомобилей, зарегистрированных на вашем аккаунте.
    </p>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var car in Model)
            {
                <div class="col d-flex">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title text-primary mb-2">@car.Brand @car.Model</h5>
                            <p class="card-text text-muted mb-1">Год: @car.Year</p>
                            <p class="card-text text-muted mb-1">VIN: @car.VIN</p>
                            <p class="card-text text-muted mb-1">Гос. номер: @car.LicensePlate</p>
                            @*  *@

                            <div class="mt-auto pt-3 border-top">
                                <a href="#" class="btn btn-outline-primary w-100 btn-sm">
                                    <i class="bi bi-info-circle me-2"></i> Детали
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-4" role="alert">
            <h4 class="alert-heading mb-3"><i class="bi bi-info-circle-fill me-2"></i> У вас пока нет зарегистрированных автомобилей.</h4>
            <p>Добавьте свой первый автомобиль, чтобы начать процесс утилизации.</p>
            <hr>
            <p class="mb-0">
                <a href="#" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i> Добавить автомобиль
                </a>
            </p>
        </div>
    }

    <div class="text-center mt-5">
        <a asp-action="Profile" asp-controller="Client" class="btn btn-outline-secondary btn-lg">
            <i class="bi bi-arrow-left me-2"></i> Вернуться в профиль
        </a>
    </div>
</div>